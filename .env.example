# База данных PostgreSQL
DATABASE_URL=jdbc:postgresql://localhost:5432/finds_prod
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_secure_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# Email настройки (Brevo)
SMTP_USERNAME=your-email@smtp-brevo.com
SMTP_PASSWORD=your-smtp-password

# JWT секрет
JWT_SECRET=your_very_secure_jwt_secret_key_at_least_256_bits_long
JWT_LIFETIME=3600000

# SSL сертификаты (путь к файлам)
SSL_CERT_PATH=./ssl/cert.pem
SSL_KEY_PATH=./ssl/key.pem
